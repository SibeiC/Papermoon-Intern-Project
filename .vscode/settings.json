{
    "editor.formatOnSave": true,
    "solidity.formatter": "prettier",
    "solidity.linter": "solhint",
    "[solidity]": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.solhint": "explicit"
        }
    },
    "files.autoSave": "onFocusChange",
}