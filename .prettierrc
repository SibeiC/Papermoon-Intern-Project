{
    "printWidth": 100,
    "tabWidth": 4,
    "singleQuote": false,
    "semi": true,
    "plugins": [
        "prettier-plugin-solidity"
    ],
    "overrides": [
        {
            "files": "*.sol",
            "options": {
                "parser": "solidity-parse"
            }
        }
    ]
}